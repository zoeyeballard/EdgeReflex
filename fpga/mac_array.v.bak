/*
 * mac_array.v - Parallel INT8 MAC Array for Layer 1
 * 
 * Purpose: Compute dot product of 304-element INT8 feature vector with 304×64 INT8 weight matrix.
 *          Output: 64 INT8 results (one per neuron), saturated from INT32 accumulators.
 * 
 * Interface:
 *   clk         - 50 MHz clock
 *   rst_n       - Active-low reset
 *   start       - Pulse to start computation
 *   features    - 304×8 = 2432-bit parallel input (all feature vector)
 *   weights     - 64×304×8 matrix (all Layer 1 weights) — NOTE: this is large!
 *   results     - 64×8 = 512-bit parallel output (ReLU results come after)
 *   mac_done    - Pulse when all 64 results ready
 * 
 * Architecture:
 *   - 64 parallel MAC pipelines (one per neuron)
 *   - Each pipeline: 304 INT8×INT8 multipliers feeding into INT32 accumulator
 *   - Pipeline depth: 8 stages (to fit in reasonable timing at 50 MHz)
 *   - Accumulation happens over multiple cycles; results valid after 8 clock cycles
 *   - For simplicity in this baseline, use pipelined adder tree (Kogge-Stone or similar)
 * 
 * Timing:
 *   Cycle 0: features and weights strobed in, start asserted
 *   Cycle 1-7: Pipelined multipliers and adders
 *   Cycle 8: Results ready, mac_done asserted
 *   
 * Saturation logic:
 *   INT32 accumulator values may overflow. Saturate to [-128, +127] for output.
 *   Saturation: if acc > 127: out = 127; if acc < -128: out = -128; else out = acc[7:0]
 */

module mac_array (
    input clk,
    input rst_n,
    input start,
    
    // 304×8-bit feature vector (all at once)
    input [2431:0] features,    // 304 × 8-bit values
    
    // 64×304×8-bit weight matrix (organized as 64 rows of 304 bytes each)
    input [19455:0] weights,    // 64 neurons × 304 × 8-bit
    
    // 64×8-bit output results
    output reg [511:0] results,
    output reg mac_done
);

    // Pipeline depth: 8 cycles (fixed latency)
    localparam PIPE_DEPTH = 8;
    localparam signed [31:0] SAT_POS = 32'sd127;
    localparam signed [31:0] SAT_NEG = -32'sd128;
    
    // Counters and state
    reg [9:0] dot_index;        // 0..303 (which feature/weight pair we're on)
    reg [5:0] neuron_index;     // 0..63 (which neuron we're computing)
    reg [6:0] compute_cycle;    // Counter for the 8-cycle pipeline
    
    // 64 accumulators (one per neuron, 32 bits to hold sum)
    reg [31:0] acc [63:0];
    
    // Pipeline registers for intermediate results
    reg [31:0] pipe_acc [63:0] [PIPE_DEPTH-1:0];  // acc[stage][neuron]
    reg [PIPE_DEPTH-1:0] pipe_valid;
    
    integer n, i, stage;
    
    // Extract 8-bit signed values from packed arrays
    function signed [7:0] get_feature (input [2431:0] data, input [8:0] idx);
        get_feature = data[idx*8 +: 8];
    endfunction
    
    function signed [7:0] get_weight (input [19455:0] data, input [5:0] neuron, input [8:0] idx);
        get_weight = data[(neuron*304 + idx)*8 +: 8];
    endfunction
    
    always @(posedge clk or negedge rst_n) begin
        if (~rst_n) begin
            for (n = 0; n < 64; n = n + 1) acc[n] <= 32'b0;
            for (stage = 0; stage < PIPE_DEPTH; stage = stage + 1) begin
                for (n = 0; n < 64; n = n + 1) begin
                    pipe_acc[n][stage] <= 32'b0;
                end
            end
            pipe_valid <= {PIPE_DEPTH{1'b0}};
            dot_index <= 10'b0;
            neuron_index <= 6'b0;
            compute_cycle <= 7'b0;
            mac_done <= 1'b0;
            results <= 512'b0;
        end else begin
            mac_done <= 1'b0;  // Default: clear pulse
            
            // Shift valid bits through pipeline
            pipe_valid <= {pipe_valid[PIPE_DEPTH-2:0], start};
            
            if (start) begin
                // Initialize accumulators for new computation
                for (n = 0; n < 64; n = n + 1) acc[n] <= 32'b0;
                dot_index <= 10'b0;
                compute_cycle <= 7'b0;
            end else if (compute_cycle < 7'd38) begin
                // Accumulate stage: process ~8 features per cycle for all 64 neurons
                // Each cycle, add 8 products to each neuron's accumulator
                
                for (n = 0; n < 64; n = n + 1) begin
                    // Compute 8 products this cycle and add to running sum
                    // For simplicity in simulation, just accumulate one at a time
                    if (dot_index < 10'd304) begin
                        acc[n] <= acc[n] + ($signed(get_feature(features, dot_index)) * $signed(get_weight(weights, n[5:0], dot_index)));
                    end
                end
                
                dot_index <= dot_index + 10'd1;
                if (dot_index == 10'd303) begin
                    // Last feature; wait for pipelining to clear
                    compute_cycle <= 7'd38;
                end
            end
            
            // Pipelined storage for saturation stage
            for (stage = PIPE_DEPTH-1; stage > 0; stage = stage - 1) begin
                for (n = 0; n < 64; n = n + 1) begin
                    pipe_acc[n][stage] <= pipe_acc[n][stage-1];
                end
            end
            
            if (compute_cycle == 7'd0 && start) begin
                // Load accumulators into pipeline at stage 0
                for (n = 0; n < 64; n = n + 1) begin
                    pipe_acc[n][0] <= 32'b0;
                end
            end else if (compute_cycle == 7'd38 && dot_index == 10'd304) begin
                // Move final accumulators into pipeline for saturation
                for (n = 0; n < 64; n = n + 1) begin
                    pipe_acc[n][0] <= acc[n];
                end
                compute_cycle <= 7'd39;
            end else if (compute_cycle == 7'd39) begin
                compute_cycle <= 7'd40;
            end
            
            // Output saturation stage (after PIPE_DEPTH cycles)
            if (pipe_valid[PIPE_DEPTH-1]) begin
                mac_done <= 1'b1;
                
                for (n = 0; n < 64; n = n + 1) begin
                    if (pipe_acc[n][PIPE_DEPTH-1] > SAT_POS) begin
                        results[n*8 +: 8] <= 8'sd127;
                    end else if (pipe_acc[n][PIPE_DEPTH-1] < SAT_NEG) begin
                        results[n*8 +: 8] <= -8'sd128;
                    end else begin
                        results[n*8 +: 8] <= pipe_acc[n][PIPE_DEPTH-1][7:0];
                    end
                end
            end
        end
    end

endmodule
